# Copy to `.env.testflight` and fill values (DO NOT COMMIT real secrets)

# Xcode build (generated by Cordova in platforms/ios)
GYM_WORKSPACE=platforms/ios/App.xcworkspace
GYM_SCHEME=App
GYM_CONFIGURATION=Release
GYM_EXPORT_METHOD=app-store
# cordova-ios 8 adds visionOS support; force iOS destination to avoid gym picking visionOS
GYM_DESTINATION=generic/platform=iOS
# Must be false so entitlements (aps-environment, app groups) are embedded during archive signing.
# match installs certs/profiles before gym runs.
GYM_SKIP_CODESIGNING=false
CI_OUTPUT_DIRECTORY=./build
CI_DERIVED_DATA_PATH=./build/DerivedData

# Build number (CFBundleVersion). Example: 410
# BUILD_NUMBER=
# Marketing version (CFBundleShortVersionString). If omitted, taken from package.json version.
# APP_VERSION=1.0.0

# App identifiers (main app + extensions)
APP_IDENTIFIER=com.reteno.example-app
MATCH_TYPE=appstore
# Add/remove extensions depending on what your iOS platform contains
MATCH_APP_IDENTIFIER=com.reteno.example-app,com.reteno.example-app.NotificationServiceExtension,com.reteno.example-app.NotificationContentExtension

# Signing (match)
MATCH_GIT_URL=git@ssh.gitlab.yalantis.com:yespo-sdk/certificates.git
FASTLANE_TEAM_ID=X9JJR3XKX7

# Apple ID used for match / Developer Portal authentication
# MATCH_USERNAME=your.appleid@example.com

# Password used by match to decrypt the certificates repo (only if your match repo is encrypted and CI can't prompt you)
# MATCH_PASSWORD=
# Force legacy (CBC) encryption when machine OpenSSL/Ruby can't handle match v2 (GCM)
# MATCH_FORCE_LEGACY_ENCRYPTION=true

# If your Apple ID has 2FA and CI is non-interactive, use a session cookie
# FASTLANE_SESSION=

# App Store Connect API key
APP_STORE_CONNECT_API_KEY_ISSUER_ID=YOUR_ISSUER_ID
APP_STORE_CONNECT_API_KEY_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_API_KEY_IN_HOUSE=false
# Option A: provide path to AuthKey_XXXX.p8 locally/CI
# APP_STORE_CONNECT_API_KEY_PATH=/path/to/AuthKey_XXXX.p8
# Option B: fetch .p8 from a git repo
# APP_STORE_CONNECT_API_KEY_GIT_REPO_URL=git@...
# APP_STORE_CONNECT_API_KEY_GIT_REPO_BRANCH=main
