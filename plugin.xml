<?xml version='1.0' encoding='utf-8'?>
<plugin id="reteno-cordova-plugin" version="0.0.1" xmlns="http://apache.org/cordova/ns/plugins/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>cordova-plugin-reteno</name>
    <engines>
        <engine name="cordova-android" version=">=12.0.0" />
    </engines>
    <!-- Android Reteno SDK (FCM) version override -->
    <preference name="ANDROID_RETENO_FCM_VERSION" default="2.8.9" />
    <preference name="SDK_ACCESS_KEY" default="" />
    <hook type="before_plugin_install" src="scripts/validate-install.js" />
    <js-module name="cordova-plugin-reteno" src="www/cordova-plugin-reteno.js">
        <clobbers target="retenosdk" />
    </js-module>

<platform name="android">
    <config-file target="AndroidManifest.xml" parent="/manifest">
        <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    </config-file>

    <config-file target="AndroidManifest.xml" parent="/manifest/application">
        <meta-data android:name="com.reteno.SDK_ACCESS_KEY" android:value="$SDK_ACCESS_KEY" />
    </config-file>

  <config-file target="config.xml" parent="/*">
    <feature name="RetenoPlugin">
      <param name="android-package" 
             value="com.reteno.plugin.RetenoPlugin"/>
    </feature>
  </config-file>
  
  <framework src="src/android/reteno.gradle" custom="true" type="gradleReference" />
  
  <source-file 
      src="src/android/app/src/main/java/com/reteno/plugin/RetenoPlugin.java" 
      target-dir="src/com/reteno/plugin" />
  <source-file 
      src="src/android/app/src/main/java/com/reteno/plugin/RetenoEvent.java" 
      target-dir="src/com/reteno/plugin" />
  <source-file 
      src="src/android/app/src/main/java/com/reteno/plugin/RetenoPushReceiver.java" 
      target-dir="src/com/reteno/plugin" />
  <source-file 
      src="src/android/app/src/main/java/com/reteno/plugin/RetenoUserAttributes.java" 
      target-dir="src/com/reteno/plugin" />
  <source-file 
      src="src/android/app/src/main/java/com/reteno/plugin/RetenoUtil.java" 
      target-dir="src/com/reteno/plugin" />
</platform>
</plugin>
